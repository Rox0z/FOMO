# Database
DATABASE_URL="postgresql://user:password@localhost:5432/fomo"

# JWT — REQUIRED. Use a strong random secret (min 32 chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_use_a_strong_random_secret_min_32_chars"

# Token expiry
JWT_EXPIRATION="24h"

# Server port
PORT=3000

# CORS — comma-separated list of allowed frontend origins
# Development default: http://localhost:4200
# Production example: https://fomo.example.com,https://admin.fomo.example.com
ALLOWED_ORIGINS="http://localhost:4200,http://localhost:3000"

# Image uploads — ImgBB API key
IMGBB_API_KEY="your_imgbb_api_key_here"
